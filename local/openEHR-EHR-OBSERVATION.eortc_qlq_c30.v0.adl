											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 16: Constipation ==========

									ELEMENT[at0019] occurrences matches {0..1} matches {    -- Q16: Constipated
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 17: Diarrhoea ==========

									ELEMENT[at0020] occurrences matches {0..1} matches {    -- Q17: Had diarrhoea
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 18: Fatigue (3 of 3) ==========

									ELEMENT[at0021] occurrences matches {0..1} matches {    -- Q18: Tired
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 19: Pain (2 of 2) ==========

									ELEMENT[at0022] occurrences matches {0..1} matches {    -- Q19: Pain interfered with daily activities
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 20: Cognitive Functioning (1 of 2) ==========

									ELEMENT[at0023] occurrences matches {0..1} matches {    -- Q20: Difficulty concentrating
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Items 21-24: Emotional Functioning ==========

									ELEMENT[at0024] occurrences matches {0..1} matches {    -- Q21: Felt tense
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0025] occurrences matches {0..1} matches {    -- Q22: Worried
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0026] occurrences matches {0..1} matches {    -- Q23: Felt irritable
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0027] occurrences matches {0..1} matches {    -- Q24: Felt depressed
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 25: Cognitive Functioning (2 of 2) ==========

									ELEMENT[at0028] occurrences matches {0..1} matches {    -- Q25: Difficulty remembering
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
