												units matches {"1"}
												magnitude matches {|0.0..100.0|}
											}
										}
									}
									ELEMENT[at0036] occurrences matches {0..1} matches {    -- Emotional Functioning score (EF)
										value matches {
											DV_QUANTITY matches {
												units matches {"1"}
												magnitude matches {|0.0..100.0|}
											}
										}
									}
									ELEMENT[at0037] occurrences matches {0..1} matches {    -- Cognitive Functioning score (CF)
										value matches {
											DV_QUANTITY matches {
												units matches {"1"}
												magnitude matches {|0.0..100.0|}
											}
										}
									}
									ELEMENT[at0038] occurrences matches {0..1} matches {    -- Social Functioning score (SF)
										value matches {
