											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 13: Appetite Loss ==========

									ELEMENT[at0016] occurrences matches {0..1} matches {    -- Q13: Lacked appetite
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Items 14-15: Nausea and Vomiting ==========

									ELEMENT[at0017] occurrences matches {0..1} matches {    -- Q14: Felt nauseated
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
