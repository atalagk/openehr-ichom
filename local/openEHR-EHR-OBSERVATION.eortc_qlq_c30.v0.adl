archetype (adl_version=1.4; uid=9f8a7b6c-5d4e-3f2a-1b0c-9d8e7f6a5b4c)
	openEHR-EHR-OBSERVATION.eortc_qlq_c30.v0

concept
	[at0000]

language
	original_language = <[ISO_639-1::en]>

description
	original_author = <
		["date"] = <"2025-03-27">
		["name"] = <"ICHOM openEHR Project">
		["organisation"] = <"openehr-ichom">
	>
	lifecycle_state = <"in_development">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record responses to the EORTC QLQ-C30 Version 3.0 (European Organisation for Research and Treatment of Cancer Quality of Life Questionnaire Core 30), a 30-item validated self-report questionnaire assessing health-related quality of life in cancer patients.">
			keywords = <"EORTC","QLQ-C30","quality of life","QoL","patient-reported outcome","PROM","cancer","functioning","symptoms">
			copyright = <"openehr-ichom">
			use = <"Use to record patient responses to the EORTC QLQ-C30 Version 3.0 questionnaire and computed subscale scores.

Items 1-28 are rated on a 4-point Likert scale: 1=Not at all, 2=A little, 3=Quite a bit, 4=Very much.
Items 29-30 (global health status and QoL) use a 7-point scale: 1=Very poor, 7=Excellent.

Scale scores are linear transformations to a 0-100 range following the EORTC QLQ-C30 scoring manual (Fayers et al., 2001).
- Functional scales (PF, RF, EF, CF, SF, QL): higher score = better functioning/QoL.
- Symptom scales and single items (FA, NV, PA, DY, SL, AP, CO, DI, FI): higher score = more severe symptoms.

Intended for use within the ICHOM Breast Cancer PROMs composition at collection timepoints: baseline (pre-treatment), 6 months post-surgery, 1 year, and annually thereafter.">
			misuse = <"Not to be used for the EORTC breast cancer-specific module — use OBSERVATION.eortc_qlq_br45.v0 for that purpose.
Not to be used to record clinical assessments by healthcare professionals — use appropriate EVALUATION or OBSERVATION archetypes.">
		>
	>

definition
	OBSERVATION[at0000] matches {    -- EORTC QLQ-C30
		data matches {
			HISTORY[at0001] matches {    -- Event Series
				events cardinality matches {1..*; unordered} matches {
					POINT_EVENT[at0002] occurrences matches {0..*} matches {    -- Any point in time
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {

									-- ========== Items 1-5: Physical Functioning ==========

									ELEMENT[at0004] occurrences matches {0..1} matches {    -- Q1: Strenuous activities
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {    -- Q2: Long walk
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0006] occurrences matches {0..1} matches {    -- Q3: Short walk outside
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0007] occurrences matches {0..1} matches {    -- Q4: Need to stay in bed or chair
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- Q5: Need help with self-care
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Items 6-7: Role Functioning ==========

									ELEMENT[at0009] occurrences matches {0..1} matches {    -- Q6: Limited in work or daily activities
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Q7: Limited in hobbies or leisure
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 8: Dyspnoea ==========

									ELEMENT[at0011] occurrences matches {0..1} matches {    -- Q8: Short of breath
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 9: Pain (1 of 2) ==========

									ELEMENT[at0012] occurrences matches {0..1} matches {    -- Q9: Had pain
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 10: Fatigue (1 of 3) ==========

									ELEMENT[at0013] occurrences matches {0..1} matches {    -- Q10: Needed to rest
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Item 11: Insomnia ==========

									ELEMENT[at0014] occurrences matches {0..1} matches {    -- Q11: Trouble sleeping
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
											4.0|[local::at0054]     -- Very much
										}
