											4.0|[local::at0054]     -- Very much
										}
									}

									-- ========== Items 29-30: Global Health Status / QoL (7-point) ==========

									ELEMENT[at0032] occurrences matches {0..1} matches {    -- Q29: Overall health
										value matches {
											1.0|[local::at0055],    -- 1 - Very poor
											2.0|[local::at0056],    -- 2
											3.0|[local::at0057],    -- 3
											4.0|[local::at0058],    -- 4
											5.0|[local::at0059],    -- 5
											6.0|[local::at0060],    -- 6
											7.0|[local::at0061]     -- 7 - Excellent
										}
									}
									ELEMENT[at0033] occurrences matches {0..1} matches {    -- Q30: Overall quality of life
										value matches {
											1.0|[local::at0055],    -- 1 - Very poor
											2.0|[local::at0056],    -- 2
											3.0|[local::at0057],    -- 3
											4.0|[local::at0058],    -- 4
											5.0|[local::at0059],    -- 5
											6.0|[local::at0060],    -- 6
											7.0|[local::at0061]     -- 7 - Excellent
										}
									}

									-- ========== Scale scores (DV_QUANTITY 0..100) ==========

									ELEMENT[at0034] occurrences matches {0..1} matches {    -- Physical Functioning score (PF)
										value matches {
											DV_QUANTITY matches {
												units matches {"1"}
												magnitude matches {|0.0..100.0|}
