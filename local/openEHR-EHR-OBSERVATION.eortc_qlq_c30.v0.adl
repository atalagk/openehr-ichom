												magnitude matches {|0.0..100.0|}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0049] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0050] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"EORTC QLQ-C30">
					description = <"The European Organisation for Research and Treatment of Cancer Quality of Life Questionnaire Core 30 (EORTC QLQ-C30) Version 3.0. A 30-item self-report questionnaire assessing health-related quality of life in cancer patients.">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point in time">
					description = <"Default, unspecified point in time which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Q1: Strenuous activities">
					description = <"Do you have any trouble doing strenuous activities, like carrying a heavy shopping bag or a suitcase?">
					comment = <"QLQ-C30 item 1. Contributes to Physical Functioning (PF) scale.">
				>
				["at0005"] = <
					text = <"Q2: Long walk">
					description = <"Do you have any trouble taking a long walk?">
					comment = <"QLQ-C30 item 2. Contributes to Physical Functioning (PF) scale.">
				>
				["at0006"] = <
					text = <"Q3: Short walk outside">
					description = <"Do you have any trouble taking a short walk outside of the house?">
					comment = <"QLQ-C30 item 3. Contributes to Physical Functioning (PF) scale.">
				>
				["at0007"] = <
					text = <"Q4: Need to stay in bed or chair">
					description = <"Do you need to stay in bed or a chair for most of the day?">
					comment = <"QLQ-C30 item 4. Contributes to Physical Functioning (PF) scale.">
				>
				["at0008"] = <
					text = <"Q5: Need help with self-care">
					description = <"Do you need help with eating, dressing, washing yourself or using the toilet?">
					comment = <"QLQ-C30 item 5. Contributes to Physical Functioning (PF) scale.">
				>
				["at0009"] = <
					text = <"Q6: Limited in work or daily activities">
					description = <"Were you limited in doing either your work or other daily activities?">
					comment = <"QLQ-C30 item 6. During the past week. Contributes to Role Functioning (RF) scale.">
				>
				["at0010"] = <
					text = <"Q7: Limited in hobbies or leisure">
					description = <"Were you limited in pursuing your hobbies or other leisure time activities?">
					comment = <"QLQ-C30 item 7. During the past week. Contributes to Role Functioning (RF) scale.">
				>
				["at0011"] = <
					text = <"Q8: Short of breath">
					description = <"Were you short of breath?">
					comment = <"QLQ-C30 item 8. During the past week. Single item: Dyspnoea (DY).">
				>
				["at0012"] = <
					text = <"Q9: Had pain">
					description = <"Have you had pain?">
					comment = <"QLQ-C30 item 9. During the past week. Contributes to Pain (PA) scale.">
				>
				["at0013"] = <
					text = <"Q10: Needed to rest">
					description = <"Did you need to rest?">
					comment = <"QLQ-C30 item 10. During the past week. Contributes to Fatigue (FA) scale.">
				>
				["at0014"] = <
					text = <"Q11: Trouble sleeping">
					description = <"Have you had trouble sleeping?">
					comment = <"QLQ-C30 item 11. During the past week. Single item: Insomnia (SL).">
				>
				["at0015"] = <
					text = <"Q12: Felt weak">
					description = <"Have you felt weak?">
					comment = <"QLQ-C30 item 12. During the past week. Contributes to Fatigue (FA) scale.">
				>
				["at0016"] = <
					text = <"Q13: Lacked appetite">
					description = <"Have you lacked appetite?">
					comment = <"QLQ-C30 item 13. During the past week. Single item: Appetite Loss (AP).">
				>
				["at0017"] = <
					text = <"Q14: Felt nauseated">
					description = <"Have you felt nauseated?">
					comment = <"QLQ-C30 item 14. During the past week. Contributes to Nausea and Vomiting (NV) scale.">
				>
				["at0018"] = <
					text = <"Q15: Vomited">
					description = <"Have you vomited?">
					comment = <"QLQ-C30 item 15. During the past week. Contributes to Nausea and Vomiting (NV) scale.">
				>
				["at0019"] = <
