									}

									-- ========== Items 26-27: Social Functioning ==========

									ELEMENT[at0029] occurrences matches {0..1} matches {    -- Q26: Treatment interfered with family life
										value matches {
											1.0|[local::at0051],    -- Not at all
											2.0|[local::at0052],    -- A little
											3.0|[local::at0053],    -- Quite a bit
