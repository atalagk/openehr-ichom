archetype (adl_version=1.4; uid=2a3b4c5d-6e7f-8a9b-0c1d-2e3f4a5b6c7d)
	openEHR-EHR-OBSERVATION.eortc_qlq_br45.v0

concept
	[at0000]

language
	original_language = <[ISO_639-1::en]>

description
	original_author = <
		["date"] = <"2025-03-27">
		["name"] = <"ICHOM openEHR Project">
		["organisation"] = <"openehr-ichom">
	>
	lifecycle_state = <"in_development">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record responses to the EORTC QLQ-BR45 (European Organisation for Research and Treatment of Cancer Quality of Life Questionnaire Breast Cancer Module 45), a 45-item breast cancer-specific supplement to the EORTC QLQ-C30.">
			keywords = <"EORTC","QLQ-BR45","breast cancer","quality of life","QoL","patient-reported outcome","PROM","body image","sexual functioning">
			copyright = <"openehr-ichom">
			use = <"Use to record patient responses to the EORTC QLQ-BR45 Version 1.0 questionnaire and computed subscale scores. Administered as a supplement to EORTC QLQ-C30; items are typically numbered Q31-Q75 in the combined questionnaire.

All 45 items use a 4-point Likert scale: 1=Not at all, 2=A little, 3=Quite a bit, 4=Very much.

Items BR8 (upset about hair loss) and BR17 (sexual enjoyment / pain during sex) are conditional — see item-level comments.

Scale scores are linear transformations to a 0-100 range following the EORTC BR45 scoring manual.
- Body Image, Sexual Functioning, Breast Satisfaction: higher score = better outcome.
- Symptom scales (Arm Symptoms, Breast Symptoms, Systemic Therapy Side Effects, Endocrine Therapy Symptoms, Skin/Mucosa Symptoms, Endocrine Sexual Symptoms): higher score = more severe symptoms.

Intended for use within the ICHOM Breast Cancer PROMs composition at collection timepoints: baseline (pre-treatment), 6 months post-surgery, 1 year, and annually thereafter.

NOTE: Item wording should be verified against the official EORTC QLQ-BR45 Version 1.0 questionnaire prior to clinical use. Items BR40-BR45 in this archetype are provisional — their exact wording and scale assignments require confirmation from the EORTC BR45 scoring manual.">
			misuse = <"Not to be used as a standalone questionnaire — administer together with EORTC QLQ-C30 (OBSERVATION.eortc_qlq_c30.v0).
Not to be used for EORTC QLQ-BR23 (the predecessor instrument).">
		>
	>
	other_details = <
		["build_uid"] = <"3d01b1c0-3d87-39d9-930e-f6f33ebb23e5">
	>

definition
	OBSERVATION[at0000] matches {    -- EORTC QLQ-BR45
		data matches {
