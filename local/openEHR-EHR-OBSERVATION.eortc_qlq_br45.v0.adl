ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"EORTC QLQ-BR45">
					description = <"The European Organisation for Research and Treatment of Cancer Quality of Life Questionnaire Breast Cancer Module 45 (EORTC QLQ-BR45) Version 1.0. A 45-item breast cancer-specific supplement to the EORTC QLQ-C30.">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point in time">
					description = <"Default, unspecified point in time which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"BR1: Pain in arm or shoulder">
					description = <"Have you had any pain in your arm or shoulder?">
					comment = <"QLQ-BR45 item BR1. During the past week. Contributes to Arm Symptoms (AS) scale.">
				>
				["at0005"] = <
					text = <"BR2: Swelling in arm or hand">
					description = <"Have you had any swelling in your arm or hand?">
					comment = <"QLQ-BR45 item BR2. During the past week. Contributes to Arm Symptoms (AS) scale.">
				>
				["at0006"] = <
					text = <"BR3: Difficulty raising arm or moving it sideways">
					description = <"Was it difficult to raise your arm or to move it sideways?">
					comment = <"QLQ-BR45 item BR3. During the past week. Contributes to Arm Symptoms (AS) scale.">
				>
				["at0007"] = <
					text = <"BR4: Pain in area of affected breast">
					description = <"Have you had any pain in the area of your affected breast?">
					comment = <"QLQ-BR45 item BR4. During the past week. Contributes to Breast Symptoms (BS) scale.">
				>
				["at0008"] = <
					text = <"BR5: Swelling in area of affected breast">
					description = <"Was the area of your affected breast swollen?">
					comment = <"QLQ-BR45 item BR5. During the past week. Contributes to Breast Symptoms (BS) scale.">
				>
				["at0009"] = <
					text = <"BR6: Oversensitivity in area of affected breast">
					description = <"Was the area of your affected breast oversensitive?">
					comment = <"QLQ-BR45 item BR6. During the past week. Contributes to Breast Symptoms (BS) scale.">
				>
				["at0010"] = <
					text = <"BR7: Had hair loss">
					description = <"Have you lost any hair?">
					comment = <"QLQ-BR45 item BR7. During the past week. Single item.">
				>
				["at0011"] = <
					text = <"BR8: Upset by hair loss">
					description = <"Were you upset by the loss of your hair?">
					comment = <"QLQ-BR45 item BR8. During the past week. Conditional: answer only if BR7 score is 'A little', 'Quite a bit' or 'Very much'. Single item.">
				>
				["at0012"] = <
					text = <"BR9: Felt less physically attractive due to illness or treatment">
					description = <"Did you feel less physically attractive as a result of your illness or treatment?">
					comment = <"QLQ-BR45 item BR9. During the past week. Contributes to Body Image (BI) scale.">
				>
				["at0013"] = <
					text = <"BR10: Felt less feminine due to illness or treatment">
					description = <"Did you feel less feminine as a result of your illness or treatment?">
					comment = <"QLQ-BR45 item BR10. During the past week. Contributes to Body Image (BI) scale.">
				>
				["at0014"] = <
					text = <"BR11: Difficult to look at self naked">
					description = <"Did you find it difficult to look at yourself naked?">
					comment = <"QLQ-BR45 item BR11. During the past week. Contributes to Body Image (BI) scale.">
				>
				["at0015"] = <
