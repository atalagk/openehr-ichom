				["at0049"] = <
					text = <"Body Image score (BI)">
					description = <"Computed Body Image scale score, derived from items BR9-BR12. Linear transformation to 0-100 range per EORTC BR45 scoring manual. Higher score = better body image.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: BI.">
				>
				["at0050"] = <
					text = <"Sexual Functioning score (SexF)">
					description = <"Computed Sexual Functioning scale score, derived from items BR14-BR16. Linear transformation to 0-100 range. Higher score = better sexual functioning.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: SexF.">
				>
				["at0051"] = <
					text = <"Breast Satisfaction score (BrSat)">
					description = <"Computed Breast Satisfaction scale score, derived from items BR31-BR34. Linear transformation to 0-100 range. Higher score = more satisfaction with breast appearance.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: BrSat. New scale in BR45; not present in QLQ-BR23.">
				>
				["at0052"] = <
					text = <"Systemic Therapy Side Effects score (STSE)">
					description = <"Computed Systemic Therapy Side Effects scale score, derived from items BR18-BR24. Linear transformation to 0-100 range. Higher score = more severe side effects.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: STSE.">
				>
				["at0053"] = <
					text = <"Arm Symptoms score (AS)">
					description = <"Computed Arm Symptoms scale score, derived from items BR1-BR3. Linear transformation to 0-100 range. Higher score = more severe arm symptoms.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: AS.">
				>
				["at0054"] = <
					text = <"Breast Symptoms score (BS)">
					description = <"Computed Breast Symptoms scale score, derived from items BR4-BR6. Linear transformation to 0-100 range. Higher score = more severe breast symptoms.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: BS.">
				>
				["at0055"] = <
					text = <"Endocrine Therapy Symptoms score (ETS)">
					description = <"Computed Endocrine Therapy Symptoms scale score, derived from items BR25-BR30. Linear transformation to 0-100 range. Higher score = more severe endocrine therapy symptoms.">
					comment = <"EORTC QLQ-BR45 scale abbreviation: ETS. New scale in BR45; not present in QLQ-BR23.">
				>
				["at0056"] = <
					text = <"Skin/Mucosa Symptoms score (SkMu)">
