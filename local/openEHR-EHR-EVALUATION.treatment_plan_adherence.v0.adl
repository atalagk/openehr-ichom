archetype (adl_version=1.4; uid=2f8b4d1e-7c3a-4e9f-b6d2-5a1c0e8b2f4d)
	openEHR-EHR-EVALUATION.treatment_plan_adherence.v0

concept
	[at0000]

language
	original_language = <[ISO_639-1::en]>

description
	original_author = <
		["date"] = <"2025-03-27">
		["name"] = <"ICHOM openEHR Project">
		["organisation"] = <"openehr-ichom">
	>
	lifecycle_state = <"in_development">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record whether the recommended treatment plan (e.g. as determined by an MDT) was followed, the reason if it was not, and details of any patient treatment preference.">
			keywords = <"treatment plan","adherence","MDT","ICHOM","breast cancer","patient preference","compliance">
			copyright = <"openehr-ichom">
			use = <"Use to record whether the MDT-recommended treatment plan was followed. If not followed, record the reason(s) and any relevant patient preference information.

Also use to record a structured patient education score (Likert scale 1–5).

Intended for use in the ICHOM Breast Cancer Treatment Record composition to capture ICHOM variables: TreatmentPlanFollowed, TreatmentPlanNotFollowed, PatientTreatPref, and PatientEducation.">
			misuse = <"Not to be used to record the treatment plan itself — use EVALUATION.recommendation or ACTION archetypes for that purpose.

Not to be used to record patient-reported outcomes — use appropriate OBSERVATION archetypes (PROMs).">
		>
	>

definition
	EVALUATION[at0000] matches {    -- Treatment plan adherence
		data matches {
			ITEM_TREE[at0001] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0002] occurrences matches {0..1} matches {    -- Plan followed
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0010,    -- Yes
									at0011,    -- No
									at0012]    -- Partially
								}
							}
						}
					}
					ELEMENT[at0003] occurrences matches {0..*} matches {    -- Reason not followed
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0013,    -- Patient preference
									at0014,    -- Clinical decision
									at0015,    -- Not indicated / not applicable
									at0016]    -- Unknown
								}
							}
						}
					}
					ELEMENT[at0004] occurrences matches {0..1} matches {    -- Patient preference detail
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0005] occurrences matches {0..1} matches {    -- Patient education score
						value matches {
							DV_ORDINAL matches {
								1|[local::at0017],    -- 1 - Very poor
								2|[local::at0018],    -- 2 - Poor
								3|[local::at0019],    -- 3 - Moderate
								4|[local::at0020],    -- 4 - Good
								5|[local::at0021]     -- 5 - Very good
							}
						}
					}
					ELEMENT[at0006] occurrences matches {0..1} matches {    -- Comment
						value matches {
							DV_TEXT matches {*}
						}
					}
					allow_archetype CLUSTER[at0007] occurrences matches {0..*} matches {    -- Referenced plan
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0008] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0009] occurrences matches {0..1} matches {    -- Last updated
						value matches {
							DV_DATE_TIME matches {*}
						}
					}
					allow_archetype CLUSTER[at0022] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Treatment plan adherence">
					description = <"Assessment of whether a recommended treatment plan (typically from an MDT meeting) was followed, including the reason if not followed and patient preference details.">
				>
				["at0001"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Plan followed">
					description = <"Was the MDT-recommended treatment plan followed?">
					comment = <"Maps to ICHOM variable: TreatmentPlanFollowed.">
				>
				["at0003"] = <
					text = <"Reason not followed">
					description = <"Reason(s) why the recommended treatment plan was not or only partially followed. Record one instance per reason.">
					comment = <"Maps to ICHOM variable: TreatmentPlanNotFollowed. Multiple instances allowed.">
				>
				["at0004"] = <
					text = <"Patient preference detail">
					description = <"Free-text description of the patient's treatment preference, if patient preference contributed to the plan not being followed.">
					comment = <"Maps to ICHOM variable: PatientTreatPref.">
				>
				["at0005"] = <
					text = <"Patient education score">
					description = <"Rating of the quality of education and information provided to the patient about their treatment options, on a 5-point Likert scale from Very poor to Very good.">
					comment = <"Maps to ICHOM variable: PatientEducation. Score: 1=Very poor, 2=Poor, 3=Moderate, 4=Good, 5=Very good.">
				>
				["at0006"] = <
					text = <"Comment">
					description = <"Additional free-text information about treatment plan adherence not captured in other fields.">
				>
				["at0007"] = <
					text = <"Referenced plan">
					description = <"Structured reference to the treatment plan or recommendation that was or was not followed.">
				>
				["at0008"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0009"] = <
					text = <"Last updated">
					description = <"Date this adherence record was last updated.">
				>
				["at0010"] = <
					text = <"Yes">
					description = <"The recommended treatment plan was followed in full.">
				>
				["at0011"] = <
					text = <"No">
					description = <"The recommended treatment plan was not followed.">
				>
				["at0012"] = <
					text = <"Partially">
					description = <"The recommended treatment plan was partially followed.">
				>
				["at0013"] = <
					text = <"Patient preference">
					description = <"The patient declined or modified the recommended plan based on personal preference.">
				>
				["at0014"] = <
					text = <"Clinical decision">
					description = <"A clinical decision was made to deviate from the recommended plan (e.g. due to comorbidities, change in clinical status).">
				>
				["at0015"] = <
					text = <"Not indicated / not applicable">
					description = <"The recommended treatment was not indicated or not applicable at the time of treatment.">
				>
				["at0016"] = <
					text = <"Unknown">
					description = <"The reason why the treatment plan was not followed is unknown.">
				>
				["at0017"] = <
					text = <"1 - Very poor">
					description = <"The patient received very poor education and information about their treatment options.">
				>
				["at0018"] = <
					text = <"2 - Poor">
					description = <"The patient received poor education and information about their treatment options.">
				>
				["at0019"] = <
					text = <"3 - Moderate">
					description = <"The patient received moderate education and information about their treatment options.">
				>
				["at0020"] = <
					text = <"4 - Good">
					description = <"The patient received good education and information about their treatment options.">
				>
				["at0021"] = <
					text = <"5 - Very good">
					description = <"The patient received very good education and information about their treatment options.">
				>
				["at0022"] = <
					text = <"Extension">
					description = <"Additional information required to extend the model with local content or to align with other reference models or formalisms.">
					comment = <"For example: local information requirements; or additional metadata to align with FHIR or CIMI equivalents.">
				>
			>
		>
	>
