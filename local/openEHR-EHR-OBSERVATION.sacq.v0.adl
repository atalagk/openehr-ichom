	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"SACQ">
					description = <"Self-Administered Comorbidity Questionnaire (SACQ). A patient-reported instrument assessing the presence, treatment, and activity limitation caused by 13 common comorbid conditions, plus up to two patient-nominated additional conditions.">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point in time">
					description = <"Default, unspecified point in time which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Heart disease">
					description = <"Patient-reported heart disease comorbidity, including presence, treatment, and activity limitation.">
					comment = <"SACQ condition 1.">
