archetype (adl_version=1.4; uid=7f3e2d1c-0b9a-4e8f-a5d6-3c2b1a0e9f8d)
	openEHR-EHR-OBSERVATION.sacq.v0

concept
	[at0000]

language
	original_language = <[ISO_639-1::en]>

description
	original_author = <
		["date"] = <"2026-04-02">
		["name"] = <"ICHOM openEHR Project">
		["organisation"] = <"openehr-ichom">
	>
	lifecycle_state = <"in_development">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record patient-reported comorbidities using the Self-Administered Comorbidity Questionnaire (SACQ), a validated instrument in which patients self-report the presence of common medical conditions, whether they receive treatment for each, and whether each limits their activities.">
			keywords = <"SACQ","comorbidity","self-administered","patient-reported","chronic disease","multimorbidity","ICHOM">
			copyright = <"openehr-ichom">
			use = <"Use to capture ICHOM Breast Cancer Standard Set v5.1 comorbidity data at baseline (pre-treatment).

The SACQ (Sangha et al., 2003, Arthritis Rheum) lists 13 common medical conditions. For each condition, patients answer three questions:
1. Do you have this condition? (Yes/No)
2. Do you receive treatment for it? (Yes/No)
3. Does it limit your activities? (Yes/No)

Patients may also record up to two additional conditions not listed.

Total score = sum of all 'Yes' responses across presence, treatment, and limitation questions (range 0-39 for the 13 standard conditions; up to 45 including two 'other' conditions). Higher score = greater comorbidity burden.">
			misuse = <"Not to be used to record clinician-assessed comorbidities — use EVALUATION.problem_diagnosis.v1 for that purpose.
Not to be used for the ICHOM quality of life PROMs — use OBSERVATION.eortc_qlq_c30.v0 and OBSERVATION.eortc_qlq_br45.v0.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6">
		["build_uid"] = <"f8e7d6c5-b4a3-9281-7060-5f4e3d2c1b0a">
		["references"] = <"Sangha O, Stucki G, Liang MH, Fossel AH, Katz JN. The Self-Administered Comorbidity Questionnaire: a new method to assess comorbidity for clinical and health services research. Arthritis Rheum. 2003 Apr 15;49(2):156-63.">
	>

